{
  "name": "@tradecanvas/chart",
  "version": "0.6.0",
  "type": "module",
  "description": "High-performance canvas trading chart with built-in indicators, drawing tools, and real-time streaming. Zero external dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bonguynvan/tradecanvas.git",
    "directory": "packages/library"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "trading",
    "chart",
    "canvas",
    "candlestick",
    "ohlc",
    "indicators",
    "drawing-tools",
    "technical-analysis",
    "financial-chart",
    "real-time",
    "typescript"
  ],
  "homepage": "https://github.com/bonguynvan/tradecanvas",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./widget": {
      "types": "./dist/widget/index.d.ts",
      "import": "./dist/widget/index.js",
      "require": "./dist/widget/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tradecanvas/commons": "workspace:*",
    "@tradecanvas/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
