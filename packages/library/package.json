{
  "name": "@tradecanvas/chart",
  "version": "0.1.1",
  "type": "module",
  "description": "High-performance canvas trading chart with built-in indicators, drawing tools, and real-time streaming. Zero external dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bonguynvan/tradecanvas.git",
    "directory": "packages/library"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": ["trading", "chart", "canvas", "candlestick", "ohlc", "indicators", "drawing-tools", "technical-analysis", "financial-chart", "real-time", "typescript"],
  "homepage": "https://github.com/bonguynvan/tradecanvas",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tradecanvas/commons": "workspace:*",
    "@tradecanvas/core": "workspace:*"
  }
}
