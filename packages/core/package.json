{
  "name": "@tradecanvas/core",
  "version": "0.1.1",
  "type": "module",
  "description": "Canvas rendering engine for @tradecanvas/chart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bonguynvan/tradecanvas.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": ["trading", "chart", "canvas", "types"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tradecanvas/commons": "workspace:*"
  }
}
