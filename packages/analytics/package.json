{
  "name": "@tradecanvas/analytics",
  "version": "0.9.0",
  "type": "module",
  "description": "Backtesting, portfolio tracking, and risk analytics for TradeCanvas — bar-by-bar Backtester with virtual fills, commission/slippage models, and risk metrics (Sharpe, Sortino, Calmar, max drawdown).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bonguynvan/tradecanvas.git",
    "directory": "packages/analytics"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "trading",
    "backtest",
    "backtesting",
    "analytics",
    "risk-metrics",
    "portfolio",
    "sharpe",
    "sortino",
    "tradecanvas"
  ],
  "homepage": "https://github.com/bonguynvan/tradecanvas",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@tradecanvas/commons": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
