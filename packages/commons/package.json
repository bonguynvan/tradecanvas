{
  "name": "@tradecanvas/commons",
  "version": "0.3.0",
  "type": "module",
  "description": "Shared types and utilities for @tradecanvas/chart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bonguynvan/tradecanvas.git",
    "directory": "packages/commons"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "trading",
    "chart",
    "canvas",
    "types"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  }
}
